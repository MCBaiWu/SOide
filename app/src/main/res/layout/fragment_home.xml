<?xml version="1.0" encoding="utf-8"?>
<!--
  极简版 HomeFragment。
  - 用最基本的 TextView / Button，不依赖 ?attr/textAppearance*，颜色全部硬编码，
    避免主题里某项没解析到导致所有文字/按钮都不可见。
  - 内容用 ScrollView 包起来，防止内容超出屏幕看不到。
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题卡（用普通 LinearLayout 加背景色，避免 MaterialCardView 解析问题） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFD9E2FF"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOide"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FF001B3E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android ELF/.SO 文件分析工具"
                android:textSize="14sp"
                android:textColor="#FF001B3E"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.3.2"
                android:textSize="12sp"
                android:textColor="#FF001B3E"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 简介 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="从底部选择一个功能开始：解析 SO 文件、解码 C++ 符号、查看历史记录、进制转换、汇编 / 反汇编。"
            android:textSize="15sp"
            android:textColor="#FF1B1B1F"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="3dp" />

        <!-- 功能标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="主要功能"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FF1B1B1F"
            android:layout_marginTop="24dp" />

        <!-- 4 个导航按钮：普通 Button，硬编码颜色，确保一定可见 -->
        <Button
            android:id="@+id/btn_open_parse"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/tab_parse"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#FF1A6EF0"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btn_open_demangle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/tab_demangle"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#FF1A6EF0"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_open_tools"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/tab_tools"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#FF1A6EF0"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_open_assembler"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/tab_assembler"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#FF1A6EF0"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
